    LITTLESKIN_CLIENT_SECRET = ""

    # JWT 密钥（生产环境务必修改）
    JWT_SECRET = os.environ.get("JWT_SECRET", "dev-jwt-secret-change-me")

    # DeepSeek API 密钥
    DEEPSEEK_API_KEY = "sk-"

    # 数据库文件路径
    DATABASE_PATH = "chats.db"

    # 日志目录
    LOG_DIR = os.environ.get("LOG_DIR", "logs")

    # TTS 服务地址（vocal_infer 服务）
    TTS_BASE_URL = os.environ.get("TTS_BASE_URL", "http://127.0.0.1:9880")

    # 本地回调服务器端口（客户端用）
    LOCAL_CALLBACK_PORT = 5001

    # 服务端运行端口
    SERVER_PORT = 5000
    SERVER_HOST = "0.0.0.0"